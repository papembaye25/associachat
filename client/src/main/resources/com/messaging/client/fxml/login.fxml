<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.messaging.client.controllers.LoginController"
           styleClass="login-root"
           stylesheets="@../styles/app.css"
           prefWidth="500" prefHeight="680">

    <!-- Cercles décoratifs en arrière-plan -->
    <Circle radius="200" fill="#6C63FF" opacity="0.05"
            translateX="-150" translateY="-200"/>
    <Circle radius="150" fill="#4B44CC" opacity="0.05"
            translateX="180" translateY="220"/>

    <VBox alignment="CENTER" spacing="0">

        <!-- Carte principale -->
        <VBox styleClass="login-card" alignment="CENTER" spacing="22" maxWidth="420">

            <!-- Logo animé -->
            <StackPane>
                <Circle radius="40"
                        style="-fx-fill: linear-gradient(to bottom right, #6C63FF, #4B44CC);
                               -fx-effect: dropshadow(gaussian, rgba(108,99,255,0.5), 20, 0, 0, 5);"/>
                <Label text="💬" style="-fx-font-size:32px;"/>
            </StackPane>

            <!-- Titre -->
            <VBox alignment="CENTER" spacing="4">
                <Label text="AssociaChat" styleClass="login-title"/>
                <Label text="Messagerie pour Associations" styleClass="login-subtitle"/>
            </VBox>

            <!-- Onglets -->
            <HBox alignment="CENTER" spacing="0"
                  style="-fx-background-color:#0F3460; -fx-background-radius:12; -fx-padding: 4;">
                <Button fx:id="btnTabLogin" text="🔑  Connexion"
                        onAction="#showLogin"
                        prefWidth="165" prefHeight="36"
                        style="-fx-background-color:#6C63FF; -fx-text-fill:white;
                               -fx-background-radius:10; -fx-font-weight:bold;
                               -fx-cursor:hand; -fx-font-size:13px;"/>
                <Button fx:id="btnTabRegister" text="✏️  Inscription"
                        onAction="#showRegister"
                        prefWidth="165" prefHeight="36"
                        style="-fx-background-color:transparent; -fx-text-fill:#A0A0B0;
                               -fx-background-radius:10; -fx-cursor:hand; -fx-font-size:13px;"/>
            </HBox>

            <!-- Formulaire LOGIN -->
            <VBox fx:id="loginForm" spacing="15" fillWidth="true">

                <VBox spacing="6">
                    <Label text="👤  NOM D'UTILISATEUR" styleClass="field-label"/>
                    <TextField fx:id="loginUsername"
                               promptText="Entrez votre nom d'utilisateur"
                               styleClass="text-field-dark"
                               prefWidth="320"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="🔒  MOT DE PASSE" styleClass="field-label"/>
                    <PasswordField fx:id="loginPassword"
                                   promptText="Entrez votre mot de passe"
                                   styleClass="password-field-dark"
                                   prefWidth="320"/>
                </VBox>

                <Label fx:id="loginError" styleClass="label-error"
                       text="" wrapText="true"/>

                <Button text="SE CONNECTER  →" onAction="#handleLogin"
                        styleClass="btn-primary" maxWidth="Infinity"
                        defaultButton="true"/>
            </VBox>

            <!-- Formulaire REGISTER -->
            <VBox fx:id="registerForm" spacing="15" fillWidth="true"
                  visible="false" managed="false">

                <VBox spacing="6">
                    <Label text="👤  NOM D'UTILISATEUR" styleClass="field-label"/>
                    <TextField fx:id="regUsername"
                               promptText="Choisissez un nom d'utilisateur"
                               styleClass="text-field-dark"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="🔒  MOT DE PASSE" styleClass="field-label"/>
                    <PasswordField fx:id="regPassword"
                                   promptText="Choisissez un mot de passe (min. 4 caractères)"
                                   styleClass="password-field-dark"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="🎭  RÔLE" styleClass="field-label"/>
                    <ComboBox fx:id="regRole"
                              promptText="Sélectionnez votre rôle"
                              styleClass="combo-box-dark"
                              maxWidth="Infinity"/>
                </VBox>

                <Label fx:id="registerMessage" text="" wrapText="true"/>

                <Button text="S'INSCRIRE  →" onAction="#handleRegister"
                        styleClass="btn-primary" maxWidth="Infinity"/>
            </VBox>

        </VBox>
    </VBox>
</StackPane>